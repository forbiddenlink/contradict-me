# Environment Configuration
# Copy this file to .env.local and fill in your values

# ============================================
# AI CONFIGURATION
# ============================================

# Groq API Key (Required for debate AI)
# Get from: https://console.groq.com
GROQ_API_KEY=gsk_xxx

# OpenAI API Key (Optional - alternative provider)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxx

# Anthropic API Key (Optional - alternative provider)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx

# ============================================
# ALGOLIA CONFIGURATION
# ============================================

# Algolia Configuration (Required for search functionality)
NEXT_PUBLIC_ALGOLIA_APP_ID=your_app_id_here
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=your_search_api_key_here

# Algolia Agent Studio (Required for chat)
ALGOLIA_AGENT_ENDPOINT=https://ai-sdk-5.api.algolia.com/1/agents/your-agent-id

# Alternative format (if your setup uses these keys)
# ALGOLIA_APP_ID=your_app_id_here
# ALGOLIA_SEARCH_API_KEY=your_search_api_key_here

# ============================================
# LANGFUSE OBSERVABILITY
# ============================================

# Langfuse Configuration (Required for LLM tracing)
# Get from: https://cloud.langfuse.com
LANGFUSE_SECRET_KEY=sk-lf-xxx
LANGFUSE_PUBLIC_KEY=pk-lf-xxx

# Optional: Self-hosted Langfuse instance
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ============================================
# RATE LIMITING (Upstash Redis)
# ============================================

# Upstash Redis (for distributed rate limiting)
# Get from: https://console.upstash.com
# Falls back to in-memory for local development if not set
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ============================================
# APP CONFIGURATION
# ============================================

# Development/Production
NODE_ENV=development

# Vercel (automatically set in Vercel deployments)
# VERCEL=1

# Axiom Log Aggregation (https://axiom.co - free 500GB/month)
NEXT_PUBLIC_AXIOM_DATASET=
AXIOM_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

NEXT_PUBLIC_POSTHOG_KEY=phc_
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
